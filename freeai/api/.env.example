# Answer backend: "codex" or "openai".
# - codex: runs the OpenAI Codex agent through the machine's ChatGPT login
#   (`codex login` once on the server machine). No API key billing.
# - openai: calls the OpenAI Responses API with OPENAI_API_KEY.
# Default: codex when OPENAI_API_KEY is not set, otherwise openai.
STUDY_GLASS_BACKEND=codex

# openai backend only.
# OPENAI_API_KEY=sk-your-server-side-key
# OPENAI_MODEL_DEFAULT=gpt-4.1-mini

# codex backend tuning (optional).
# CODEX_MODEL=gpt-5.1-codex-mini
# CODEX_TIMEOUT_MS=90000

STUDY_GLASS_CLIENT_TOKEN=replace-with-a-long-random-token
ALLOWED_ORIGIN=https://your-app.example.com
PORT=8787

# Local development only. Do not enable in production.
# STUDY_GLASS_ALLOW_UNAUTHENTICATED=true

# Enable only when your reverse proxy is configured to set X-Forwarded-For safely.
# TRUST_PROXY=true
